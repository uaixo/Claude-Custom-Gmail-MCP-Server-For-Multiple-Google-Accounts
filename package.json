{
  "name": "gmail-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Gmail with multi-account support (per-account OAuth)",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "gmail-mcp-server": "dist/index.js",
    "gmail-mcp-add-account": "dist/add-account.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "npm install && npm run build && npm run add-account",
    "start": "node dist/index.js",
    "add-account": "node --no-deprecation dist/add-account.js",
    "list-accounts": "node --no-deprecation dist/add-account.js --list",
    "remove-account": "node --no-deprecation dist/add-account.js --remove",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "node --import tsx --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@googleapis/gmail": "^12.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "google-auth-library": "^9.15.0",
    "html-to-text": "^10.0.0",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
